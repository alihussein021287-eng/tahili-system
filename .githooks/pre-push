#!/usr/bin/env bash
# يشتغل تلقائياً عند git push، إذا فعّلته بـ:
#   git config core.hooksPath .githooks
#
# يشغّل اختبارات الوحدة (سريعة) دائماً، واختبارات playwright فقط لو
# فيه سيرفر تطوير شغّال محلياً (ما نريد يفشل الهوك لأن ما فيه سيرفر شغّال).

set -e
G='\033[0;32m'; R='\033[0;31m'; Y='\033[1;33m'; N='\033[0m'

echo -e "${Y}▶ تشغيل اختبارات الوحدة قبل الرفع...${N}"
if ! npm run test --silent; then
  echo -e "${R}✘ فيه اختبارات فاشلة — الرفع متوقف. صلّح الخلل قبل لا ترفع للسيرفر.${N}"
  exit 1
fi
echo -e "${G}✔ كل اختبارات الوحدة ناجحة${N}"

if curl -s -o /dev/null --max-time 2 http://localhost:3000; then
  echo -e "${Y}▶ فيه سيرفر تطوير شغّال — تشغيل اختبار الدخان (smoke test)...${N}"
  if ! npm run test:e2e --silent; then
    echo -e "${R}✘ اختبار الدخان فشل — الرفع متوقف.${N}"
    exit 1
  fi
  echo -e "${G}✔ اختبار الدخان ناجح${N}"
else
  echo -e "${Y}⚠ ما فيه سيرفر تطوير شغّال على :3000 — تم تجاوز اختبار الدخان (اختبار الوحدة كافي هذي المرة)${N}"
fi

echo -e "${G}✔ جاهز للرفع${N}"
